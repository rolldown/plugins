{
  "react-bootstrap": {
    "transform": "react-bootstrap/lib/{{member}}"
  },
  "my-library-2": {
    "transform": "my-library-2/{{ camelCase member }}",
    "skipDefaultConversion": true
  },
  "my-library-3": {
    "transform": "my-library-3/{{ kebabCase member }}",
    "skipDefaultConversion": true
  }
}
