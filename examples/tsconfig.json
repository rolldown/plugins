{
  "compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "lib": ["es2023", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "declaration": true,
    "jsx": "react-jsx",
    "paths": {
      "~utils": ["./test-utils.ts"]
    }
  }
}
